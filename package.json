{
  "name": "dumentre-website-v2",
  "version": "1.0.0",
  "private": true,
  "description": "Dumentre marketing site (static HTML/CSS/JS) with Playwright E2E test coverage.",
  "scripts": {
    "build": "node scripts/build-static.js",
    "test:e2e": "playwright test --grep-invert @production",
    "test:e2e:ui": "playwright test --ui --grep-invert @production",
    "test:e2e:headed": "playwright test --headed --grep-invert @production",
    "test:e2e:report": "playwright show-report",
    "test:e2e:prod": "playwright test --grep @production"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
